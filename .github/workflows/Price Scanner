<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Price Scanner — نظام قراءة الأسعار الذكي</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&family=Tajawal:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #09090f;
  --bg2:       #0d0d18;
  --bg3:       #12121f;
  --surface:   #16162a;
  --surface2:  #1e1e38;
  --border:    rgba(255,255,255,0.06);
  --gold:      #e8a84c;
  --gold2:     #f5c87a;
  --gold-dim:  rgba(232,168,76,0.12);
  --cyan:      #4ecdc4;
  --cyan-dim:  rgba(78,205,196,0.10);
  --text:      #f0eff8;
  --text2:     #a09ec0;
  --text3:     #5a587a;
  --radius:    16px;
  --radius-sm: 10px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Cairo', 'Tajawal', sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  line-height: 1.7;
}

/* ── Noise Overlay ── */
body::before {
  content:'';
  position: fixed; inset:0; z-index: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; inset-inline: 0; z-index: 100;
  padding: 18px 60px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(9,9,15,0.82);
  backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--border);
}
.nav-logo {
  display: flex; align-items: center; gap: 12px;
  font-weight: 900; font-size: 1.25rem; color: var(--text);
  text-decoration: none;
}
.nav-logo .icon {
  width: 38px; height: 38px;
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  border-radius: 10px;
  display: grid; place-items: center;
  font-size: 1.1rem;
}
.nav-links {
  display: flex; align-items: center; gap: 32px;
  list-style: none;
}
.nav-links a {
  color: var(--text2); text-decoration: none;
  font-size: 0.9rem; font-weight: 500;
  transition: color .2s;
}
.nav-links a:hover { color: var(--gold); }
.nav-cta {
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  color: #09090f !important; font-weight: 700 !important;
  padding: 9px 22px; border-radius: 8px;
  transition: opacity .2s !important;
}
.nav-cta:hover { opacity: .85; }

/* ── SECTIONS ── */
section { position: relative; z-index: 1; }

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 40px;
}

/* ══ HERO ══ */
#hero {
  min-height: 100vh;
  display: flex; align-items: center;
  padding-top: 100px;
  overflow: hidden;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--gold-dim);
  border: 1px solid rgba(232,168,76,0.25);
  border-radius: 100px;
  padding: 7px 16px;
  font-size: 0.82rem; font-weight: 600;
  color: var(--gold2);
  margin-bottom: 28px;
  animation: fadeUp .6s ease both;
}

.hero-badge::before {
  content:'';
  width: 7px; height: 7px;
  background: var(--gold);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%,100%{opacity:1;transform:scale(1)}
  50%{opacity:.4;transform:scale(1.5)}
}

h1 {
  font-size: clamp(2.4rem, 4vw, 3.6rem);
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 24px;
  animation: fadeUp .7s .1s ease both;
}

h1 .accent { color: var(--gold); }
h1 .accent2 { color: var(--cyan); }

.hero-desc {
  font-size: 1.1rem;
  color: var(--text2);
  max-width: 480px;
  margin-bottom: 40px;
  font-weight: 400;
  animation: fadeUp .7s .2s ease both;
}

.hero-actions {
  display: flex; gap: 14px; flex-wrap: wrap;
  animation: fadeUp .7s .3s ease both;
}

.btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  color: #09090f; font-weight: 700; font-size: 1rem;
  padding: 14px 30px; border-radius: 10px;
  text-decoration: none; border: none; cursor: pointer;
  transition: transform .2s, box-shadow .2s;
  box-shadow: 0 8px 32px rgba(232,168,76,0.3);
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(232,168,76,0.4); }

.btn-secondary {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--surface); color: var(--text);
  font-weight: 600; font-size: 1rem;
  padding: 14px 30px; border-radius: 10px;
  text-decoration: none; border: 1px solid var(--border);
  transition: background .2s, border-color .2s;
}
.btn-secondary:hover { background: var(--surface2); border-color: rgba(255,255,255,.15); }

.hero-stats {
  display: flex; gap: 32px; margin-top: 52px;
  padding-top: 32px;
  border-top: 1px solid var(--border);
  animation: fadeUp .7s .4s ease both;
}
.stat-item { text-align: center; }
.stat-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.8rem; font-weight: 700;
  color: var(--gold);
}
.stat-label { font-size: 0.8rem; color: var(--text3); font-weight: 500; }

/* ── Hero Visual ── */
.hero-visual {
  position: relative;
  animation: fadeUp .9s .2s ease both;
}

.scanner-mockup {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 28px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 40px 100px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.04);
}
.scanner-mockup::before {
  content:'';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 30% 0%, rgba(232,168,76,.08), transparent 60%);
}

.mockup-topbar {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 20px;
}
.dot { width:10px;height:10px;border-radius:50%; }
.dot.red{background:#ff5f56} .dot.yellow{background:#ffbd2e} .dot.green{background:#27c93f}

.mockup-title {
  flex: 1; text-align: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem; color: var(--text3);
}

.search-bar {
  background: var(--bg2);
  border: 2px solid var(--gold);
  border-radius: 10px;
  padding: 14px 18px;
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 24px;
  box-shadow: 0 0 20px rgba(232,168,76,0.15);
}
.search-bar .barcode-icon { font-size: 1.4rem; }
.search-bar input {
  background: none; border: none; outline: none;
  color: var(--text); font-family: 'JetBrains Mono', monospace;
  font-size: 1rem; width: 100%;
  caret-color: var(--gold);
}

.scan-line {
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  border-radius: 2px;
  animation: scanAnim 2s ease-in-out infinite;
  margin-bottom: 20px;
}
@keyframes scanAnim {
  0%,100%{opacity:0;transform:scaleX(0.3)}
  50%{opacity:1;transform:scaleX(1)}
}

.result-card {
  background: var(--bg3);
  border: 1px solid rgba(232,168,76,0.2);
  border-radius: 12px;
  padding: 18px;
}
.result-name { font-weight: 700; font-size: 1rem; color: var(--text); margin-bottom: 10px; }
.result-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.result-label { font-size: 0.78rem; color: var(--text3); }
.result-value { font-family: 'JetBrains Mono', monospace; font-size: 0.88rem; color: var(--cyan); }
.result-price { font-size: 1.4rem; font-weight: 900; color: var(--gold); }

.expiry-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(78,205,196,0.12); color: var(--cyan);
  border: 1px solid rgba(78,205,196,0.25);
  border-radius: 6px; padding: 3px 10px; font-size: 0.76rem; font-weight: 600;
}

.floating-tag {
  position: absolute;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 0.78rem;
  font-weight: 600;
  backdrop-filter: blur(10px);
  animation: float 4s ease-in-out infinite;
}
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

.tag-db { top: -18px; left: -20px; color: var(--cyan); animation-delay: 0s; }
.tag-excel { bottom: 30px; left: -30px; color: var(--gold); animation-delay: 1.5s; }
.tag-live { top: 50px; right: -25px; color: #a78bfa; animation-delay: 0.8s; }

/* ── SECTION TITLES ── */
.section-header {
  text-align: center;
  margin-bottom: 64px;
}
.section-tag {
  display: inline-block;
  font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 14px;
}
.section-tag::before, .section-tag::after {
  content: '──';
  margin: 0 10px;
  opacity: .4;
}
.section-title {
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  font-weight: 900; line-height: 1.2;
  margin-bottom: 16px;
}
.section-desc {
  color: var(--text2); max-width: 580px; margin: 0 auto;
  font-size: 1rem;
}

/* ── DIVIDER ── */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
  margin: 0 auto;
}

/* ══ DATA SOURCES ══ */
#data-sources { padding: 110px 0; }

.sources-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20px;
}

.source-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px;
  position: relative;
  overflow: hidden;
  transition: border-color .3s, transform .3s;
}
.source-card::before {
  content:'';
  position:absolute; inset:0;
  background: var(--gold-dim);
  opacity: 0;
  transition: opacity .3s;
}
.source-card:hover { border-color: rgba(232,168,76,0.35); transform: translateY(-4px); }
.source-card:hover::before { opacity: 1; }

.source-card.featured {
  grid-column: span 2;
  background: linear-gradient(135deg, var(--surface) 60%, rgba(232,168,76,0.06));
  border-color: rgba(232,168,76,0.2);
}

.source-icon {
  width: 52px; height: 52px;
  border-radius: 12px;
  display: grid; place-items: center;
  font-size: 1.5rem;
  margin-bottom: 20px;
}
.source-icon.green { background: rgba(39,201,63,0.12); }
.source-icon.blue  { background: rgba(78,205,196,0.12); }
.source-icon.gold  { background: var(--gold-dim); }
.source-icon.purple{ background: rgba(167,139,250,0.12); }

.source-title { font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; }
.source-desc  { font-size: 0.88rem; color: var(--text2); line-height: 1.7; margin-bottom: 18px; }

.source-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.tag {
  background: var(--bg2); color: var(--text3);
  border: 1px solid var(--border);
  border-radius: 6px; padding: 4px 10px;
  font-size: 0.75rem; font-family: 'JetBrains Mono', monospace;
  font-weight: 600;
}

.db-list {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 8px; margin-top: 16px;
}
.db-item {
  display: flex; align-items: center; gap: 8px;
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; padding: 10px 12px;
  font-size: 0.82rem; font-weight: 600; color: var(--text2);
}
.db-dot { width:6px;height:6px;border-radius:50%;background:var(--cyan); flex-shrink:0; }

/* ══ FEATURES ══ */
#features { padding: 110px 0; background: var(--bg2); }

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
}

.feature-cell {
  background: var(--surface);
  padding: 36px 30px;
  position: relative;
  transition: background .25s;
}
.feature-cell:hover { background: var(--surface2); }
.feature-cell.wide { grid-column: span 2; }

.feature-icon {
  font-size: 2rem; margin-bottom: 16px;
  display: block;
}
.feature-title { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; }
.feature-desc { font-size: 0.86rem; color: var(--text2); line-height: 1.75; }

.feature-list {
  list-style: none; margin-top: 14px;
}
.feature-list li {
  display: flex; align-items: flex-start; gap: 8px;
  font-size: 0.84rem; color: var(--text2); margin-bottom: 7px;
}
.feature-list li::before {
  content: '◈';
  color: var(--gold); font-size: 0.7rem; margin-top: 4px; flex-shrink: 0;
}

/* ══ APPEARANCE ══ */
#appearance { padding: 110px 0; }

.appear-grid {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: 60px;
  align-items: center;
}

.appear-content h2 {
  font-size: 2.2rem; font-weight: 900;
  margin-bottom: 20px; line-height: 1.2;
}
.appear-content p {
  color: var(--text2); margin-bottom: 32px; font-size: 0.95rem;
}

.appear-options { display: flex; flex-direction: column; gap: 14px; }
.appear-option {
  display: flex; align-items: center; gap: 14px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 16px 20px;
  transition: border-color .25s, background .25s;
  cursor: default;
}
.appear-option:hover { border-color: rgba(232,168,76,0.3); background: var(--surface2); }
.appear-option-icon {
  width: 40px; height: 40px; border-radius: 9px;
  display: grid; place-items: center;
  font-size: 1.1rem; flex-shrink: 0;
}
.appear-option-icon.gold { background: var(--gold-dim); }
.appear-option-icon.blue { background: rgba(78,205,196,0.1); }
.appear-option-icon.purple { background: rgba(167,139,250,0.1); }
.appear-option-text .title { font-weight: 700; font-size: 0.92rem; margin-bottom: 3px; }
.appear-option-text .sub { color: var(--text2); font-size: 0.8rem; }

/* ── App Mockup ── */
.appear-visual { position: relative; }

.app-mockup-wrap {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 40px 100px rgba(0,0,0,.7), 0 0 0 1px rgba(255,255,255,.06);
  aspect-ratio: 16/9;
  font-family: 'Cairo', sans-serif;
}

/* backgrounds */
.app-bg {
  position: absolute; inset: 0;
  transition: opacity .5s ease;
  opacity: 0;
  pointer-events: none;
}
.app-bg.active { opacity: 1; }

.bg-color   { background: linear-gradient(135deg,#1a2e1a 0%,#0d1a2e 100%); }
.bg-image   {
  background:
    linear-gradient(rgba(0,0,0,.52),rgba(0,0,0,.52)),
    repeating-linear-gradient(45deg,#1a2a1a 0px,#243324 40px,#1e2d1e 40px,#2a3d2a 80px);
}
.bg-slideshow {
  background: linear-gradient(135deg,#2a1a0d 0%,#1a0d2a 50%,#0d2a1a 100%);
  animation: bgSlide 3s ease-in-out infinite alternate;
}
@keyframes bgSlide {
  from{ background: linear-gradient(135deg,#2a1a0d,#0d2a1a); }
  to  { background: linear-gradient(225deg,#0d1a2a,#2a0d1a); }
}
.bg-video {
  background: url('https://picsum.photos/seed/cinema55/900/506') center/cover no-repeat;
}
.bg-video::after {
  content:'';
  position:absolute;inset:0;
  background: rgba(0,0,0,.3);
  animation: videoFlicker 3s ease-in-out infinite alternate;
}
@keyframes videoFlicker {
  0%  { backdrop-filter: brightness(.85) saturate(1.1); }
  50% { backdrop-filter: brightness(.7)  saturate(1.3) hue-rotate(8deg); }
  100%{ backdrop-filter: brightness(.9)  saturate(1.0); }
}
.bg-album-video { position: absolute; inset: 0; }

/* overlay dim */
.app-overlay {
  position: absolute; inset: 0; z-index: 2;
  background: rgba(0,0,0,.38);
}

/* topbar */
.app-topbar {
  position: absolute; top: 0; inset-inline: 0; z-index: 10;
  background: rgba(0,0,0,.65);
  backdrop-filter: blur(8px);
  padding: 7px 14px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid rgba(255,255,255,.08);
  font-size: .68rem;
}
.app-topbar .partner-name { color: rgba(255,255,255,.5); }
.app-topbar .app-title {
  font-family: 'JetBrains Mono', monospace;
  font-weight: 700; font-size: .7rem; color: rgba(255,255,255,.85);
  display: flex; align-items: center; gap: 6px;
}
.app-title .ver-badge {
  background: #7bc67b; color: #0a1a0a;
  border-radius: 4px; padding: 1px 6px;
  font-size: .6rem; font-weight: 700;
}
.app-topbar .inst-name { color: #fff; font-weight: 700; font-size: .72rem; }

/* update bar */
.app-update-bar {
  position: absolute; top: 30px; left: 50%; transform: translateX(-50%); z-index: 15;
  background: rgba(20,20,40,.9);
  border: 1px solid rgba(100,180,100,.3);
  border-radius: 8px;
  padding: 5px 10px;
  display: flex; align-items: center; gap: 8px;
  font-size: .62rem; white-space: nowrap;
  backdrop-filter: blur(10px);
  box-shadow: 0 4px 20px rgba(0,0,0,.4);
}
.app-update-bar .upd-btn {
  background: #5ab85a; color: #fff;
  border-radius: 5px; padding: 3px 10px;
  font-weight: 700; font-size: .62rem; cursor: pointer;
}
.app-update-bar .upd-x {
  background: rgba(255,255,255,.1);
  border-radius: 4px; padding: 2px 6px; cursor: pointer;
  font-size: .6rem; color: rgba(255,255,255,.5);
}
.app-update-bar .upd-text { color: rgba(255,255,255,.75); }
.app-update-bar .upd-icon { font-size: .8rem; }

/* logo */
.app-logo {
  position: absolute; top: 38px; right: 14px; z-index: 10;
  background: rgba(255,255,255,.08);
  border-radius: 8px; padding: 5px 10px;
  display: flex; align-items: center; gap: 5px;
  font-size: .58rem; font-weight: 700;
  color: rgba(255,255,255,.7);
  backdrop-filter: blur(6px);
}
.app-logo .logo-icon { font-size: 1rem; }

/* clock */
.app-clock {
  position: absolute; top: 36px; left: 14px; z-index: 10;
  text-align: left; direction: ltr;
}
.app-clock .time { font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 700; color: #fff; }
.app-clock .date { font-size: .6rem; color: rgba(255,255,255,.55); margin-top: 1px; }

/* product display */
.app-product {
  position: absolute; inset: 0; z-index: 8;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 60px 20px 60px;
}
.app-field-label {
  font-size: .62rem; color: rgba(255,255,255,.5);
  margin-bottom: 2px;
  letter-spacing: .05em;
}
.app-code {
  font-family: 'JetBrains Mono', monospace;
  font-size: .88rem; color: rgba(255,255,255,.7);
  margin-bottom: 8px;
}
.app-pname {
  font-size: 1.45rem; font-weight: 900;
  color: #fff;
  margin-bottom: 10px;
  text-shadow: 0 2px 12px rgba(0,0,0,.5);
  line-height: 1.2;
}
.app-price-row {
  display: flex; align-items: baseline; gap: 6px;
  justify-content: center;
}
.app-price {
  font-family: 'JetBrains Mono', monospace;
  font-size: 2.1rem; font-weight: 900;
  color: #b5f542;
  text-shadow: 0 0 30px rgba(181,245,66,.4);
}
.app-currency {
  font-size: .9rem; font-weight: 700;
  color: #b5f542;
}

/* qty info */
.app-qty-info {
  position: absolute; bottom: 50px; left: 50%; transform: translateX(-50%);
  z-index: 10;
  font-family: 'JetBrains Mono', monospace;
  font-size: .7rem; color: rgba(255,255,255,.45);
}

/* expiry table */
.app-expiry {
  position: absolute; bottom: 28px; right: 14px; z-index: 10;
  background: rgba(0,0,0,.75);
  border-radius: 8px; overflow: hidden;
  min-width: 140px;
  backdrop-filter: blur(8px);
  font-size: .6rem;
}
.app-expiry-header {
  display: grid; grid-template-columns: 1fr 1fr 14px;
  gap: 0; padding: 4px 8px;
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.45);
  font-weight: 700;
  border-bottom: 1px solid rgba(255,255,255,.06);
  direction: ltr;
}
.app-expiry-row {
  display: grid; grid-template-columns: 1fr 1fr 14px;
  gap: 0; padding: 4px 8px;
  border-bottom: 1px solid rgba(255,255,255,.04);
  align-items: center;
  direction: ltr;
}
.app-expiry-row:last-child { border-bottom: none; }
.app-expiry-row.exp  { background: rgba(200,50,50,.15); }
.app-expiry-row.warn { background: rgba(200,150,50,.1); }
.app-expiry-row.ok   { background: transparent; }
.exp-icon  { font-size: .65rem; margin-left: 4px; }
.exp-date  { color: rgba(255,255,255,.75); direction: ltr; font-family: 'JetBrains Mono', monospace; }
.exp-qty   { color: rgba(255,255,255,.6); direction: ltr; font-family: 'JetBrains Mono', monospace; }
.row-exp  .exp-date { color: #ff7070; }
.row-warn .exp-date { color: #ffcc44; }
.row-ok   .exp-date { color: #7bc67b; }

/* bottom bar */
.app-bottombar {
  position: absolute; bottom: 0; inset-inline: 0; z-index: 10;
  background: rgba(0,0,0,.7);
  border-top: 1px solid rgba(255,255,255,.06);
  padding: 5px 12px;
  display: flex; align-items: center; justify-content: space-between;
  backdrop-filter: blur(8px);
}
.app-scans {
  display: flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 5px; padding: 2px 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: .6rem; color: rgba(255,255,255,.6);
}
.app-scans .scans-num { color: #fff; font-weight: 700; }
.app-search-bar {
  flex: 1; margin: 0 10px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 5px; height: 18px;
  position: relative; overflow: hidden;
}
.app-search-bar::after {
  content:'';
  position:absolute; top:0; bottom:0; left:0;
  width: 30%; background: rgba(255,255,255,.12);
  animation: searchPulse 2s ease-in-out infinite;
}
@keyframes searchPulse { 0%,100%{left:0%;width:0%} 50%{left:20%;width:60%} }
.app-icons {
  display: flex; gap: 5px;
}
.app-icons span {
  width: 18px; height: 18px; border-radius: 4px;
  background: rgba(255,255,255,.07);
  display: grid; place-items: center;
  font-size: .55rem; cursor: pointer;
  transition: background .2s;
}
.app-icons span:hover { background: rgba(255,255,255,.15); }

/* scan confirm */
.app-scan-confirm {
  position: absolute; bottom: 24px; inset-inline: 0; z-index: 11;
  text-align: center;
  font-size: .6rem; color: rgba(255,255,255,.4);
}

/* pills */
.transition-pills {
  display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap;
}
.pill {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 100px; padding: 7px 16px;
  font-size: 0.8rem; color: var(--text2); cursor: pointer;
  transition: background .25s, border-color .25s, color .25s, transform .15s;
  user-select: none;
}
.pill:hover { background: var(--surface2); border-color: rgba(255,255,255,.15); transform: translateY(-1px); }
.pill.active {
  background: var(--gold-dim); border-color: var(--gold);
  color: var(--gold); transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(232,168,76,.2);
}

/* pill label */
.bg-label {
  position: absolute; top: 34px; left: 50%; transform: translateX(-50%);
  z-index: 20; opacity: 0;
  background: rgba(0,0,0,.7);
  color: var(--gold);
  border: 1px solid rgba(232,168,76,.3);
  border-radius: 100px;
  padding: 3px 14px; font-size: .65rem; font-weight: 700;
  pointer-events: none;
  transition: opacity .3s;
  white-space: nowrap;
  backdrop-filter: blur(8px);
}
.bg-label.show { opacity: 1; }

/* ══ EXPIRY ══ */
#expiry { padding: 110px 0; background: var(--bg2); }

.expiry-layout {
  display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
}

.expiry-table {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.expiry-table-header {
  background: var(--bg);
  padding: 14px 20px;
  display: grid; grid-template-columns: 1fr 1fr 1fr auto;
  gap: 10px;
  font-size: 0.78rem; font-weight: 700; color: var(--text3);
  border-bottom: 1px solid var(--border);
}
.expiry-row {
  padding: 13px 20px;
  display: grid; grid-template-columns: 1fr 1fr 1fr auto;
  gap: 10px;
  font-size: 0.82rem;
  border-bottom: 1px solid var(--border);
  transition: background .2s;
  align-items: center;
}
.expiry-row:hover { background: var(--surface2); }
.expiry-row:last-child { border-bottom: none; }
.expiry-row.warn { background: rgba(232,168,76,.05); border-right: 3px solid var(--gold); }
.expiry-row.expired { background: rgba(255,80,80,.05); border-right: 3px solid #ff5050; }
.badge-warn { background: rgba(232,168,76,.15); color: var(--gold); border-radius:5px; padding:2px 8px; font-size:.72rem; font-weight:700; }
.badge-exp  { background: rgba(255,80,80,.15); color: #ff6b6b; border-radius:5px; padding:2px 8px; font-size:.72rem; font-weight:700; }
.badge-ok   { background: rgba(39,201,63,.12); color: #27c93f; border-radius:5px; padding:2px 8px; font-size:.72rem; font-weight:700; }
.badge-Count   { background: rgba(39,201,63,.12); color: #27c93f; border-radius:5px; padding:2px 8px; font-size:.72rem; font-weight:700; }

.expiry-features { display: flex; flex-direction: column; gap: 20px; }
.expiry-feature {
  display: flex; gap: 16px;
}
.ef-icon {
  width: 44px; height: 44px; border-radius: 10px;
  display: grid; place-items: center;
  font-size: 1.2rem; flex-shrink: 0;
}
.ef-icon.gold { background: var(--gold-dim); }
.ef-icon.red  { background: rgba(255,80,80,.1); }
.ef-icon.cyan { background: var(--cyan-dim); }
.ef-title { font-weight: 700; font-size: 0.92rem; margin-bottom: 5px; }
.ef-desc  { font-size: 0.83rem; color: var(--text2); line-height: 1.6; }

/* ══ MULTILANG ══ */
#multilang { padding: 110px 0; }

.lang-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.lang-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px;
  text-align: center;
  transition: border-color .25s, transform .25s;
}
.lang-card:hover { border-color: rgba(232,168,76,0.3); transform: translateY(-3px); }
.lang-flag { font-size: 2.5rem; margin-bottom: 12px; }
.lang-name { font-size: 1.2rem; font-weight: 700; margin-bottom: 6px; }
.lang-code {
  display: inline-block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem; color: var(--gold);
  background: var(--gold-dim); border-radius:5px; padding:2px 10px;
  margin-bottom: 12px;
}
.lang-dir { font-size: 0.82rem; color: var(--text2); }

.currency-grid {
  display: flex; flex-wrap: wrap; gap: 12px;
  justify-content: center;
  margin-top: 48px;
}
.currency-item {
  display: flex; align-items: center; gap: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 20px;
  transition: border-color .2s;
}
.currency-item:hover { border-color: rgba(232,168,76,0.3); }
.currency-symbol {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.3rem; font-weight: 700; color: var(--gold);
}
.currency-name { font-size: 0.84rem; color: var(--text2); }

/* ══ PARTNER SYSTEM ══ */
#partner { padding: 110px 0; background: var(--bg2); }

.partner-grid {
  display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: start;
}

.partner-levels {
  display: flex; flex-direction: column; gap: 14px;
}
.level-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 22px;
  position: relative; overflow: hidden;
  transition: border-color .25s;
}
.level-card::before {
  content: '';
  position: absolute; inset: 0 auto 0 0;
  width: 3px;
}
.level-card.dev::before { background: #a78bfa; }
.level-card.partner::before { background: var(--cyan); }
.level-card.user::before { background: var(--gold); }
.level-card:hover { border-color: rgba(255,255,255,.12); }
.level-title { font-weight: 700; font-size: 0.95rem; margin-bottom: 6px; }
.level-desc  { font-size: 0.82rem; color: var(--text2); line-height: 1.6; }
.level-badge {
  position: absolute; top: 14px; left: 16px;
  font-size: 0.7rem; font-weight: 700;
  padding: 2px 9px; border-radius: 100px;
}
.level-badge.dev    { background: rgba(167,139,250,.12); color: #a78bfa; }
.level-badge.partner{ background: var(--cyan-dim); color: var(--cyan); }
.level-badge.user   { background: var(--gold-dim); color: var(--gold2); }

.partner-features-right { display: flex; flex-direction: column; gap: 16px; }
.pf-item {
  display: flex; gap: 14px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18px;
  transition: border-color .25s;
}
.pf-item:hover { border-color: rgba(232,168,76,.2); }
.pf-item-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 2px; }
.pf-item-title { font-weight: 700; font-size: 0.9rem; margin-bottom: 5px; }
.pf-item-desc  { font-size: 0.82rem; color: var(--text2); line-height: 1.6; }

/* ══ PRICING ══ */
#pricing { padding: 110px 0; }

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(5,1fr);
  gap: 14px;
  margin-top: 20px;
}

.price-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px 20px;
  text-align: center;
  transition: transform .25s, border-color .25s;
  position: relative;
}
.price-card:hover { transform: translateY(-5px); border-color: rgba(232,168,76,.25); }
.price-card.featured {
  border-color: var(--gold);
  background: linear-gradient(160deg, var(--surface) 60%, rgba(232,168,76,.08));
  box-shadow: 0 0 40px rgba(232,168,76,.12);
}
.featured-label {
  position: absolute; top: -12px; inset-inline: 0;
  display: flex; justify-content: center;
}
.featured-label span {
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  color: #09090f; font-weight: 700; font-size: 0.72rem;
  padding: 4px 14px; border-radius: 100px;
}
.plan-name { font-weight: 900; font-size: 1rem; margin-bottom: 6px; }
.plan-scans {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.5rem; font-weight: 700; color: var(--gold);
  margin-bottom: 4px;
}
.plan-scans-unit { font-size: 0.75rem; color: var(--text3); margin-bottom: 18px; }
.plan-price {
  font-size: 1.35rem; font-weight: 900; color: var(--text);
  margin-bottom: 4px;
}
.plan-currency { font-size: 0.78rem; color: var(--text2); }

.free-plans {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 14px;
  margin-top: 32px;
}
.free-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20px;
  text-align: center;
}
.free-card .plan-name { font-size: .9rem; color: var(--text2); }
.free-card .plan-scans { font-size: 1.2rem; color: var(--text3); }

/* ══ CTA ══ */
#cta {
  padding: 110px 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}
#cta::before {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(ellipse at 50% 50%, rgba(232,168,76,.08), transparent 65%);
}
.cta-inner { position: relative; z-index:1; }
.cta-title { font-size: clamp(2rem,3.5vw,3rem); font-weight:900; margin-bottom:16px; }
.cta-desc { color: var(--text2); font-size:1rem; max-width:480px; margin:0 auto 40px; }

.contact-methods { display:flex; gap:20px; justify-content:center; flex-wrap:wrap; margin-top:40px; }
.contact-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px 32px;
  text-align: center;
  min-width: 180px;
  transition: border-color .25s;
}
.contact-card:hover { border-color: rgba(232,168,76,.3); }
.contact-icon { font-size:1.8rem; margin-bottom:10px; }
.contact-label { font-size:.82rem; color:var(--text2); margin-bottom:4px; }
.contact-value { font-weight:700; font-size:.9rem; color: var(--text); }

/* ── FOOTER ── */
footer {
  padding: 32px 0;
  border-top: 1px solid var(--border);
  text-align: center;
  font-size: .82rem; color: var(--text3);
}
footer span { color: var(--gold); }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity:0; transform: translateY(28px); }
  to   { opacity:1; transform: translateY(0); }
}

.reveal {
  opacity: 0; transform: translateY(30px);
  transition: opacity .65s ease, transform .65s ease;
}
.reveal.visible { opacity:1; transform:translateY(0); }

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width:6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--surface2); border-radius:3px; }

/* ── GLOW LINES ── */
.glow-line {
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
  opacity: .3;
  margin: 0;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  nav { padding: 14px 20px; }
  .nav-links { display: none; }
  .hero-grid, .appear-grid, .expiry-layout, .partner-grid { grid-template-columns: 1fr; }
  .sources-grid, .features-grid { grid-template-columns: 1fr; }
  .source-card.featured { grid-column: span 1; }
  .feature-cell.wide { grid-column: span 1; }
  .features-grid { background: none; border:none; gap: 1px; }
  .pricing-grid, .free-plans { grid-template-columns: 1fr 1fr; }
  .lang-grid { grid-template-columns: 1fr; }
  .container { padding: 0 20px; }
  .hero-stats { gap: 20px; }
}

.first-offers { margin-top: 30px; }
.bundle-offers-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-top: 16px;
}
.bundle-offer {
  padding: 24px;
  border: 1px solid rgba(232,168,76,.26);
  border-radius: var(--radius);
  background: linear-gradient(135deg, rgba(232,168,76,.10), rgba(34,211,238,.06));
  display: flex;
  flex-direction: column;
  gap: 18px;
  justify-content: space-between;
}
.bundle-copy h3 { margin: 10px 0 8px; font-size: 1.25rem; color: var(--text); line-height: 1.45; }
.bundle-copy p, .bundle-items { color: var(--text2); line-height: 1.8; font-size: .95rem; }
.bundle-items { margin-top: 10px; }
.bundle-price-box {
  border: 1px solid rgba(255,255,255,.10);
  border-radius: var(--radius-sm);
  padding: 20px;
  background: rgba(0,0,0,.18);
  text-align: center;
}
.bundle-price { font-size: 2rem; font-weight: 800; color: var(--gold); }
.bundle-price span { font-size: 1rem; color: var(--text2); }
.bundle-old { margin-top: 8px; color: var(--text3); text-decoration: line-through; }
.bundle-discount { color: var(--cyan); font-weight: 700; }
.bundle-discount1 { color: var(--cyan); font-weight: 500; }
.featured-bundle { border-color: rgba(34,211,238,.32); background: linear-gradient(135deg, rgba(34,211,238,.10), rgba(232,168,76,.07)); }
.lifetime-bundle { border-color: rgba(167,139,250,.32); background: linear-gradient(135deg, rgba(167,139,250,.12), rgba(232,168,76,.07)); }
#new-details .features-grid {
  gap: 0;
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--radius);
  overflow: hidden;
}
#new-details .feature-card {
  border: 0;
  border-inline-end: 1px solid rgba(255,255,255,.08);
  border-bottom: 1px solid rgba(255,255,255,.08);
  border-radius: 0;
}
@media (max-width: 1000px) {
  .bundle-offers-grid { grid-template-columns: 1fr; }
}

/* Floating Language Switcher */
.lang-float {
  position: fixed;
  left: 24px;
  bottom: 24px;
  z-index: 250;
  display: flex;
  flex-direction: column-reverse;
  align-items: flex-start;
  gap: 10px;
}
.lang-toggle {
  width: 58px;
  height: 58px;
  border: 1px solid rgba(232,168,76,.36);
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  color: #09090f;
  font-weight: 900;
  font-size: .92rem;
  cursor: pointer;
  box-shadow: 0 16px 40px rgba(0,0,0,.38), 0 0 28px rgba(232,168,76,.22);
  display: grid;
  place-items: center;
  transition: transform .2s ease, box-shadow .2s ease;
}
.lang-toggle:hover { transform: translateY(-2px); box-shadow: 0 20px 48px rgba(0,0,0,.45), 0 0 34px rgba(232,168,76,.30); }
.lang-menu {
  min-width: 148px;
  padding: 8px;
  border: 1px solid rgba(255,255,255,.10);
  border-radius: 14px;
  background: rgba(13,13,24,.92);
  backdrop-filter: blur(18px);
  box-shadow: 0 18px 50px rgba(0,0,0,.34);
  opacity: 0;
  transform: translateY(8px) scale(.96);
  pointer-events: none;
  transition: opacity .18s ease, transform .18s ease;
}
.lang-float.open .lang-menu { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
.lang-option {
  width: 100%;
  border: 0;
  border-radius: 10px;
  background: transparent;
  color: var(--text2);
  cursor: pointer;
  padding: 9px 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  font-family: inherit;
  font-size: .86rem;
  transition: background .16s ease, color .16s ease;
}
.lang-option:hover, .lang-option.active { background: rgba(232,168,76,.12); color: var(--gold2); }
.lang-option span:last-child { font-family: 'JetBrains Mono', monospace; font-weight: 700; }
html[dir="ltr"] body { font-family: 'Cairo', 'Tajawal', sans-serif; }
html[dir="ltr"] .hero-grid, html[dir="ltr"] .appear-grid, html[dir="ltr"] .expiry-layout, html[dir="ltr"] .partner-grid { direction: ltr; }
html[dir="ltr"] .section-header, html[dir="ltr"] .hero-content, html[dir="ltr"] .bundle-copy, html[dir="ltr"] footer { direction: ltr; text-align: left; }
html[dir="ltr"] .nav-links { direction: ltr; }
@media (max-width: 700px) {
  .lang-float { left: 14px; bottom: 14px; }
  .lang-toggle { width: 52px; height: 52px; }
}
</style>
