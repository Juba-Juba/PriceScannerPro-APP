<script>
/* ── Language menu shell ── */
try { localStorage.removeItem('priceScannerSiteLang'); } catch { }
const langFloat = document.getElementById('langFloat');
const langToggle = document.getElementById('langToggle');
if (langToggle && langFloat) {
  langToggle.addEventListener('click', () => langFloat.classList.toggle('open'));
  document.querySelectorAll('.lang-option').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lang-option').forEach(x => x.classList.remove('active'));
      btn.classList.add('active');
      langToggle.textContent = (btn.dataset.lang || 'ar').toUpperCase();
      langFloat.classList.remove('open');
    });
  });
  document.addEventListener('click', (e) => { if (!langFloat.contains(e.target)) langFloat.classList.remove('open'); });
}
/* ── Scroll Reveal ── */
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) setTimeout(() => entry.target.classList.add('visible'), i * 80);
  });
}, { threshold: 0.10 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

/* ── Nav Active ── */
const sections = document.querySelectorAll('section[id]');
const navLinks  = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll', () => {
  let cur = '';
  sections.forEach(s => { if (window.scrollY >= s.offsetTop - 140) cur = s.id; });
  navLinks.forEach(a => { a.style.color = a.getAttribute('href') === '#'+cur ? 'var(--gold)' : ''; });
});

/* ══ SLIDESHOW ENGINE ══ */
const slideIds   = ['slide-a','slide-b','slide-c','slide-d'];
let   slideIdx   = 0;
let   slideTimer = null;

function runSlideshow() {
  if (slideTimer) clearInterval(slideTimer);
  slideIds.forEach(id => { const el = document.getElementById(id); if(el){ el.style.opacity='0'; el.style.zIndex='1'; } });
  const first = document.getElementById(slideIds[0]);
  if (first) { first.style.opacity='1'; first.style.zIndex='2'; }
  slideIdx = 0;
  slideTimer = setInterval(() => {
    const prev = document.getElementById(slideIds[slideIdx]);
    slideIdx   = (slideIdx + 1) % slideIds.length;
    const next = document.getElementById(slideIds[slideIdx]);
    if (!prev || !next) return;
    next.style.zIndex  = '3';
    next.style.opacity = '1';
    setTimeout(() => {
      prev.style.opacity = '0';
      prev.style.zIndex  = '1';
    }, 700);
  }, 2800);
}

function stopSlideshow() {
  if (slideTimer) { clearInterval(slideTimer); slideTimer = null; }
}

/* ══ VIDEO ALBUM ENGINE ══ */
const vfIds    = ['vf-0','vf-1','vf-2','vf-3'];
let   vfIdx    = 0;
let   vfTimer  = null;

function runVideoAlbum() {
  if (vfTimer) clearInterval(vfTimer);
  vfIds.forEach(id => { const el = document.getElementById(id); if(el){ el.style.opacity='0'; el.style.zIndex='1'; } });
  const first = document.getElementById(vfIds[0]);
  if (first) { first.style.opacity='1'; first.style.zIndex='2'; }
  vfIdx  = 0;
  vfTimer = setInterval(() => {
    const prev = document.getElementById(vfIds[vfIdx]);
    vfIdx = (vfIdx + 1) % vfIds.length;
    const next = document.getElementById(vfIds[vfIdx]);
    if (!prev || !next) return;
    next.style.zIndex  = '3';
    next.style.opacity = '1';
    setTimeout(() => { prev.style.opacity='0'; prev.style.zIndex='1'; }, 500);
  }, 2200);
}

function stopVideoAlbum() {
  if (vfTimer) { clearInterval(vfTimer); vfTimer = null; }
}

/* ══ PILL SWITCHER ══ */
const pills   = document.querySelectorAll('#bgPills .pill');
const bgLabel = document.getElementById('bgLabel');
let   labelTimer;

pills.forEach(pill => {
  pill.addEventListener('click', () => {
    pills.forEach(p => p.classList.remove('active'));
    pill.classList.add('active');

    /* stop any running animations */
    stopSlideshow();
    stopVideoAlbum();

    /* hide all backgrounds */
    document.querySelectorAll('.app-bg').forEach(b => b.classList.remove('active'));

    const targetId = pill.dataset.bg;
    const targetBg = document.getElementById(targetId);
    if (targetBg) targetBg.classList.add('active');

    /* start engines if needed */
    if (targetId === 'bg-slideshow')   runSlideshow();
    if (targetId === 'bg-album-video') runVideoAlbum();

    /* floating label */
    bgLabel.textContent = pill.dataset.label || pill.textContent.trim();
    bgLabel.classList.add('show');
    clearTimeout(labelTimer);
    labelTimer = setTimeout(() => bgLabel.classList.remove('show'), 2200);
  });
});

/* ── Mock Clock ── */
function updateMockClock() {
  const now = new Date();
  let h = now.getHours(), m = now.getMinutes();
  const ampm = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;
  const el = document.getElementById('mockClock');
  if (el) el.textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ' ' + ampm;
}
updateMockClock();
setInterval(updateMockClock, 30000);

/* ── Typewriter + Mockup Product Sync ── */
const scanData = [
  { code:'6221155000115', product:'باراسيتامول 500 مجم × 20', price:'32.50' },
  { code:'34871',         product:'AVIL 2CC 6AMP',              price:'57.00' },
  { code:'8001841204013', product:'شامبو بانتين 400مل',        price:'89.00' },
  { code:'5010123010006', product:'فيتامين C 1000mg',           price:'45.00' },
];
let ci = 0;
const input = document.querySelector('.search-bar input');

function fadeField(id, newVal) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.transition = 'opacity .2s';
  el.style.opacity = '0';
  setTimeout(() => {
    el.textContent = newVal;
    el.style.opacity = '1';
  }, 220);
}

function typeCode(str, el, cb) {
  el.value = ''; let j = 0;
  const t = setInterval(() => {
    el.value += str[j++];
    if (j >= str.length) { clearInterval(t); if (cb) setTimeout(cb, 500); }
  }, 70);
}

if (input) {
  setInterval(() => {
    ci = (ci + 1) % scanData.length;
    const d = scanData[ci];
    typeCode(d.code, input, () => {
      fadeField('mockCode',    d.code);
      fadeField('mockProduct', d.product);
      fadeField('mockPrice',   d.price);
    });
  }, 3800);
}
</script>

